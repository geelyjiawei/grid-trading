{
  "components": {
    "schemas": {
      "ApiConfig": {
        "properties": {
          "api_key": {
            "minLength": 1,
            "title": "Api Key",
            "type": "string"
          },
          "api_secret": {
            "minLength": 1,
            "title": "Api Secret",
            "type": "string"
          },
          "exchange": {
            "default": "bybit",
            "title": "Exchange",
            "type": "string"
          },
          "testnet": {
            "default": false,
            "title": "Testnet",
            "type": "boolean"
          }
        },
        "required": [
          "api_key",
          "api_secret"
        ],
        "title": "ApiConfig",
        "type": "object"
      },
      "GridConfig": {
        "properties": {
          "direction": {
            "title": "Direction",
            "type": "string"
          },
          "exchange": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Exchange"
          },
          "fee_rate": {
            "default": 0.0005,
            "title": "Fee Rate",
            "type": "number"
          },
          "grid_count": {
            "title": "Grid Count",
            "type": "integer"
          },
          "grid_mode": {
            "default": "arithmetic",
            "title": "Grid Mode",
            "type": "string"
          },
          "grid_order_post_only": {
            "default": false,
            "title": "Grid Order Post Only",
            "type": "boolean"
          },
          "grid_order_qty": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Grid Order Qty"
          },
          "initial_order_price": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Initial Order Price"
          },
          "initial_order_type": {
            "default": "market",
            "title": "Initial Order Type",
            "type": "string"
          },
          "leverage": {
            "default": 1,
            "title": "Leverage",
            "type": "integer"
          },
          "lower_price": {
            "title": "Lower Price",
            "type": "number"
          },
          "maker_fee_rate": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "default": 0.0002,
            "title": "Maker Fee Rate"
          },
          "position_sizing_mode": {
            "default": "investment",
            "title": "Position Sizing Mode",
            "type": "string"
          },
          "stop_loss_price": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Stop Loss Price"
          },
          "symbol": {
            "title": "Symbol",
            "type": "string"
          },
          "take_profit_price": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Take Profit Price"
          },
          "taker_fee_rate": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "default": 0.0005,
            "title": "Taker Fee Rate"
          },
          "total_investment": {
            "default": 0,
            "title": "Total Investment",
            "type": "number"
          },
          "trigger_price": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Trigger Price"
          },
          "upper_price": {
            "title": "Upper Price",
            "type": "number"
          }
        },
        "required": [
          "symbol",
          "direction",
          "upper_price",
          "lower_price",
          "grid_count"
        ],
        "title": "GridConfig",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "LoginRequest": {
        "properties": {
          "code": {
            "maxLength": 12,
            "minLength": 6,
            "title": "Code",
            "type": "string"
          },
          "password": {
            "minLength": 1,
            "title": "Password",
            "type": "string"
          },
          "username": {
            "minLength": 1,
            "title": "Username",
            "type": "string"
          }
        },
        "required": [
          "username",
          "password",
          "code"
        ],
        "title": "LoginRequest",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
