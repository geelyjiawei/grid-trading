# Preferred for server deployment: inject API credentials through environment variables.
# Supported values: bybit, binance, aster.
GRID_EXCHANGE=bybit

BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=false

BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

# AsterDEX V3 futures uses wallet signing, not HMAC API keys.
# ASTER_USER_ADDRESS is your main/login wallet address.
# ASTER_SIGNER_PRIVATE_KEY is the API Wallet private key created in Aster API Wallet.
ASTER_USER_ADDRESS=
ASTER_SIGNER_PRIVATE_KEY=
ASTER_TESTNET=false
# Optional overrides if Aster changes domains or signature parameter behavior.
ASTER_BASE_URL=https://fapi.asterdex.com
ASTER_TESTNET_BASE_URL=https://fapi.asterdex-testnet.com
ASTER_INCLUDE_USER_PARAM=true

# Optional: only required if you want to save API credentials from the web UI on Linux servers.
# Generate one with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GRID_CONFIG_KEY=
# Optional when GRID_CONFIG_KEY is a passphrase instead of a Fernet key.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
GRID_CONFIG_SALT=

# Keep encrypted UI-saved config outside the image.
GRID_CONFIG_FILE=/app/data/api_config.json
# Keep running grid state outside the image so Docker rebuild/restart can recover.
GRID_STATE_FILE=/app/data/grid_state.json
# Keep strategy run history outside the image for review and audit.
GRID_HISTORY_FILE=/app/data/grid_history.json

# Binance USDT-M futures fallback fee rates used only when exchange trade details are unavailable.
# Maker = 挂单, Taker = 吃单.
GRID_MAKER_FEE_RATE=0.0002
GRID_TAKER_FEE_RATE=0.0005

# Web login protection. Keep AUTH_REQUIRED=true on servers.
AUTH_REQUIRED=true
ADMIN_USERNAME=admin
# Generate with: python backend/auth.py hash "your-strong-password"
ADMIN_PASSWORD_HASH=
# Generate with: python backend/auth.py totp
# Add this secret manually to Google Authenticator.
TOTP_SECRET=
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=
# Set true only when using HTTPS.
AUTH_COOKIE_SECURE=false

# Optional CORS allowlist. Leave empty for same-origin only.
# Example: CORS_ALLOWED_ORIGINS=https://grid.example.com,http://127.0.0.1:8000
CORS_ALLOWED_ORIGINS=
